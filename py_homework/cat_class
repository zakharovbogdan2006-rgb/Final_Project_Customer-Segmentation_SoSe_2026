from abc import ABC, abstractmethod


class Supplier(ABC):
    def __init__(self, name: str, region: str):
        self.name = name
        self.region = region

    @abstractmethod
    def quote(self, order_amount: float) -> float:
        pass

    def fulfillment_days(self) -> int:
        return 7

    def summary(self, order_amount: float) -> str:
        quote = self.quote(order_amount)
        return f"{self.name}({self.region}): quote={quote}, days={self.fulfillment_days()}"


class DomesticSupplier(Supplier):
    def quote(self, order_amount: float) -> float:
        if order_amount <= 0:
            raise ValueError("Order amount must be positive")

        if order_amount >= 1000:
            return order_amount * 0.95

        return order_amount

    def fulfillment_days(self) -> int:
        return 5


class OverseasSupplier(Supplier):
    def __init__(self, name: str, region: str, tariff_rate: float):
        super().__init__(name, region)
        self.tariff_rate = tariff_rate

    def quote(self, order_amount: float) -> float:
        if order_amount <= 0:
            raise ValueError("Order amount must be positive")

        return order_amount * (1 + self.tariff_rate)

    def fulfillment_days(self) -> int:
        return 14