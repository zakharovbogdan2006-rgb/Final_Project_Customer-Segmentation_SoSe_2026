from abc import ABC, abstractclassmethod, abstractmethod
class Company:
    def __init__(self, company_name: str):
        self.company_name = company_name
        self.departments = []
    def add_department(self,dept:'Department'):
        self.departments.append(dept)
    def total_headcount(self) -> int:
        return sum(dept.headcount() for dept in self.departments)
    def monthly_payroll(self):
        return sum(dept.department_payroll() for dept in self.departments)
class Department:
    def __init__(self, dept_id, name:str):
        self.staff = []
        self.dept_id = dept_id
        self.name = name
        
    def hire(self, employee: "Employee") -> None:
        self.staff.append(employee)
    def headcount(self)-> int:
        return len(self.staff)
    def department_payroll(self):
        su = 0
        su = sum (self.employee.monthly_pay() for Employee.employee in self.staff )
        return su
class Employee(ABC):
    def __init__(self, emp_id,full_name):
        self.emp_id = emp_id
        self.full_name = full_name
    @abstractmethod
    def monthly_pay(self) -> float:
        pass
    @abstractmethod
    def role(self)->str:
        pass
class FullTimeEmployee(Employee):
    def __init__(self, emp_id,full_name, annual_salary ):
        super().__init__(emp_id, full_name)
        self.annual_salary = annual_salary
        if self.annual_salary <=0:
           raise ValueError("Annual salary must be positive")

    def monthly_pay(self):
        return self.annual_salary / 12
    def role(self):
        return  "Full-Time"
class Contractor(Employee):
    def __init__(self, emp_id, full_name, hourly_rate, hours_per_month):
        super().__init__(emp_id, full_name)
        self. hourly_rate= hourly_rate
        self.hours_per_month = hours_per_month
        if self.hourly_rate<=0 or self.hours_per_month <=0:
            raise ValueError("hourly_rate and hours_per_month must be positive")
    def monthly_pay(self):
        return self.hourly_rate * self.hours_per_month
    def role(self):
        return 'Contractor'

